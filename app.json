{
  "expo": {
    "name": "11408学习计划",
    "slug": "study-planner",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "newArchEnabled": true,
    "scheme": "study-planner",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#5b5fef"
    },
    "ios": {
      "supportsTablet": true,
      "bundleIdentifier": "com.studyplanner.app"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#5b5fef"
      },
      "package": "com.studyplanner.app",
      "edgeToEdgeEnabled": true
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      "expo-sqlite",
      "expo-secure-store",
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#5b5fef"
        }
      ]
    ],
    "extra": {
      "eas": {
        "projectId": "11408-study-planner"
      }
    }
  }
}
